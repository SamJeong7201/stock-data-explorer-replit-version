# ──────────────────────────────────────────────────────────────────────────────
# Stock Tracker frontend environment variables (Vite)
# All VITE_* variables are embedded at build time and visible in the browser.
# Copy this file to .env and fill in values for local development.
# ──────────────────────────────────────────────────────────────────────────────

# Port Vite dev server listens on.
# Replit sets this automatically. Falls back to 5173 if not set.
PORT=5174

# Base path for the app (used for Replit path-based routing).
# Set to "/" on Vercel, Netlify, or any standard host.
# Replit sets this automatically to the artifact's preview path.
BASE_PATH=/

# Full URL of the API server.
# Leave empty (or don't set) to use relative paths — works when
# the frontend and API are served from the same origin (e.g. Replit dev,
# or a monolithic Vercel deployment with rewrites).
# Set to your deployed API URL when they are on different domains:
#   VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_BASE_URL=
