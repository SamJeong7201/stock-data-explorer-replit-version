# ──────────────────────────────────────────────────────────────────────────────
# API Server environment variables
# Copy this file to .env and fill in real values for local development.
# On Replit, set these as Secrets. On Vercel, set them as Environment Variables.
# ──────────────────────────────────────────────────────────────────────────────

# Port the Express server listens on.
# Replit sets this automatically. Locally you can pick any free port.
PORT=8080

# OpenAI-compatible API endpoint (Replit AI Integration proxy or OpenAI directly).
# On Replit: provided automatically via the AI Integration.
# On Vercel/elsewhere: set to https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# API key for the OpenAI-compatible endpoint.
# On Replit: provided automatically via the AI Integration.
# On Vercel/elsewhere: your OpenAI API key (sk-...).
AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key-here
